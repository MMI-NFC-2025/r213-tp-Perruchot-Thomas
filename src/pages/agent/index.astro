---
import Layout from "../../layouts/Layout.astro";
import { getAgents } from "../../js/backend.mjs";
import '../../styles/global.css';

const agents = await getAgents();
---

<Layout titre="Nos Agents">
    <div class="max-w-7xl mx-auto px-8 py-12">
        <a href="/" class="text-[10px] uppercase tracking-[0.2em] font-bold text-black hover:text-gray-400 mb-10 inline-block transition-colors">
            ← Retour à l'accueil
        </a>

        <h1 class="text-5xl font-light uppercase tracking-tighter text-black mb-16">
            L'Équipe.
        </h1>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            {agents.map((agent) => (
                <a href={`/agent/${agent.id}`} class="group border border-gray-100 p-8 hover:border-black transition-all duration-500">
                    <h2 class="text-xl font-light uppercase tracking-tight mb-2">
                        {agent.prenom} {agent.nom}
                    </h2>
                    <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-6">
                        {agent.email}
                    </p>
                    <span class="text-[10px] uppercase tracking-[0.2em] font-bold border-b border-black pb-1 group-hover:text-gray-400 group-hover:border-gray-400 transition-all">
                        Voir ses biens →
                    </span>
                </a>
            ))}
        </div>
    </div>
</Layout>