---
import { getOffresParSurface } from '../../../js/backend.mjs';
import Layout from "../../../layouts/Layout.astro";
import OffreCard from '../../../components/OffreCard.astro'; 
import '../../../styles/global.css'

const { surface } = Astro.params;
const offres = await getOffresParSurface(surface);
---

<Layout titre={`Maisons > ${surface} m²`}>
    <main class="max-w-7xl mx-auto px-4 py-8">
        <a href="/offres" class="inline-flex items-center text-[10px] uppercase tracking-[0.2em] font-bold text-black hover:text-gray-400 mb-10 transition-colors group">
            <span class="mr-3 transition-transform group-hover:-translate-x-1">←</span> 
            Retour aux offres
        </a>

        <header class="mb-12">
            <h1 class="text-5xl font-light uppercase tracking-tighter text-black mb-4">
                Espaces > {surface} m².
            </h1>
            <p class="text-[10px] uppercase tracking-widest text-gray-400">
                Découvrez nos propriétés spacieuses sélectionnées pour vous.
            </p>
        </header>

        {offres.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                {offres.map((offre) => (
                    <div class="offre" data-favori={offre.favori?.toString() || "false"}>
                        <OffreCard offre={offre} />
                    </div>
                ))}
            </div>
        ) : (
            <div class="py-20 border border-gray-100 text-center">
                <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400">
                    Aucune offre ne correspond à cette surface pour le moment.
                </p>
            </div>
        )}
    </main>
</Layout>