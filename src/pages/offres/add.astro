---
import '../../styles/global.css'
import Layout from '../../layouts/Layout.astro';
import { addOffre } from '../../js/backend.mjs';

let message = '';
if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const response = await addOffre(formData);
    message = response.message;
}
---

<Layout titre="Ajouter une offre">
    <div class="max-w-2xl mx-auto">
        <h1 class="text-4xl font-light uppercase tracking-tighter mb-12 text-black">
            Nouvelle Offre.
        </h1>
        
        {message && (
            <div class={`mb-8 p-4 text-[10px] uppercase tracking-widest border ${message.includes('succès') 
                ? 'bg-white border-black text-black' 
                : 'bg-gray-50 border-gray-200 text-gray-500'}`}>
                {message}
            </div>
        )}

        <form action="/offres/add" method="POST" enctype="multipart/form-data" class="space-y-10">
            <div class="space-y-6">
                <div>
                    <label class="block text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 mb-2">Nom de la maison</label>
                    <input type="text" name="nomMaison" placeholder="Ex: Villa Minimaliste" required 
                           class="w-full border-b border-gray-200 focus:border-black p-2 bg-transparent outline-none transition-colors text-sm" />
                </div>

                <div>
                    <label class="block text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 mb-2">Adresse</label>
                    <input type="text" name="adresse" placeholder="Ex: 123 Rue du Design, Paris" required 
                           class="w-full border-b border-gray-200 focus:border-black p-2 bg-transparent outline-none transition-colors text-sm" />
                </div>

                <div>
                    <label class="block text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 mb-2">Prix (€)</label>
                    <input type="number" name="prix" placeholder="0.00" required 
                           class="w-full border-b border-gray-200 focus:border-black p-2 bg-transparent outline-none transition-colors text-sm" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div>
                    <label class="block text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 mb-2">Salles de bain</label>
                    <input type="number" name="nbSdb" placeholder="2" 
                           class="w-full border-b border-gray-200 focus:border-black p-2 bg-transparent outline-none transition-colors text-sm" />
                </div>
                <div>
                    <label class="block text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 mb-2">Chambres</label>
                    <input type="number" name="nbChambres" placeholder="3" 
                           class="w-full border-b border-gray-200 focus:border-black p-2 bg-transparent outline-none transition-colors text-sm" />
                </div>
                <div>
                    <label class="block text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 mb-2">Superficie (m²)</label>
                    <input type="number" name="surface" placeholder="120" 
                           class="w-full border-b border-gray-200 focus:border-black p-2 bg-transparent outline-none transition-colors text-sm" />
                </div>
            </div>

            <div class="pt-4">
                <label class="block text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400 mb-4">Images du bien</label>
                <div class="relative border-2 border-dashed border-gray-100 p-8 text-center hover:border-black transition-colors group">
                    <input type="file" name="image" multiple
                           class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                    <p class="text-[10px] uppercase tracking-widest text-gray-400 group-hover:text-black transition-colors">
                        Glisser ou sélectionner les fichiers
                    </p>
                </div>
            </div>
            
            <button type="submit" class="w-full bg-black text-white text-[10px] uppercase tracking-[0.3em] font-bold py-5 hover:bg-gray-800 transition-all shadow-sm">
                Enregistrer l'offre
            </button>
        </form>
        
        <div class="mt-12 text-center">
            <a href="/offres" class="text-[10px] uppercase tracking-[0.2em] text-gray-400 hover:text-black transition-colors border-b border-transparent hover:border-black pb-1">
                Annuler et revenir
            </a>
        </div>
    </div>
</Layout>