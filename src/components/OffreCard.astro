---
import PbImage from './PbImage.astro';
const { offre } = Astro.props;
---

<div class="bg-white border border-gray-100 overflow-hidden transition-all duration-500 hover:border-black relative group">
    
    <button 
        class="favoriteButton absolute top-4 left-4 z-20 bg-black text-white p-2 rounded-full hover:scale-110 transition-transform shadow-lg flex items-center justify-center w-8 h-8"
        data-offre={JSON.stringify(offre)}
    >
        <span id="favorite-icon" class="text-xs">
            {offre.favori ? "★" : "☆"}
        </span>
    </button>

    <div class="grid grid-cols-3 gap-[1px] w-full aspect-video bg-gray-100 overflow-hidden border-b border-gray-100">
        <PbImage 
            record={offre} 
            recordImage={offre.image?.[0]} 
            class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105 col-span-2" 
        />
        <div class="grid grid-rows-2 gap-[1px] h-full">
            <PbImage 
                record={offre} 
                recordImage={offre.image?.[1]} 
                class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0" 
            />
            <PbImage 
                record={offre} 
                recordImage={offre.image?.[2]} 
                class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0" 
            />
        </div>
    </div>
    
    <div class="p-6 text-left">
        <h2 class="text-sm uppercase tracking-[0.15em] font-bold text-black mb-1">
            {offre.nomMaison}
        </h2>
        <p class="text-xs text-gray-400 uppercase tracking-widest mb-4">
            {offre.surface} m² — {offre.prix.toLocaleString()} €
        </p>
        
        <a href={`/offres/${offre.id}`} class="inline-block text-[10px] uppercase tracking-[0.2em] font-bold border-b border-black pb-1 hover:text-gray-400 hover:border-gray-400 transition-all">
            Découvrir le bien
        </a>
    </div>
</div>

<script>
    //@ts-nocheck
    import { setFavori } from "../js/backend.mjs";
    
    const favoriteButtons = document.querySelectorAll(".favoriteButton");

    favoriteButtons.forEach(button => {
        button.addEventListener('click', async (e) => {
            e.preventDefault(); 
            
            const offreData = JSON.parse(button.dataset.offre || '{}');
            const newFavori = !offreData.favori;

            await setFavori(offreData);

            const favIcon = button.querySelector('#favorite-icon');
            if (favIcon) {
                favIcon.textContent = newFavori ? "★" : "☆";
            }
            
            offreData.favori = newFavori;
            button.dataset.offre = JSON.stringify(offreData);
        });
    });
</script>