---
/* src/components/PbImage.astro */
import { getImageUrl } from '../js/backend.mjs';
import { Image } from "astro:assets";

const {
  record,
  recordImage,
  width = 800,   
  height = 600, 
  class: className, 
} = Astro.props;

const imageURL = await getImageUrl(record, recordImage);
---

{imageURL && 
    <Image
        src={imageURL}
        alt={record.nomMaison || 'Image de la maison'}
        width={width}
        height={height}
        class={className}
        loading="lazy"
    />
}